{
  "name": "@nutrition/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "yarn --cwd ../.. workspace @nutrition/shared build",
    "build": "nest build",
    "predev": "yarn --cwd ../.. workspace @nutrition/shared build",
    "dev": "nest start --watch",
    "start:decrypted": "node dist/main",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^8.2.0",
    "@prisma/client": "^6.4.0",
    "fastify": "^5.2.0",
    "nestjs-zod": "^4.3.0",
    "nodemailer": "^6.9.16",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.6.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.0",
    "@nutrition/shared": "*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.4.0",
    "typescript": "^5.7.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  }
}
