{
  "name": "nutrition-assistant",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "yarn workspace @nutrition/api dev",
    "dev:api:encrypted": "node scripts/run-with-encrypted-env.mjs \"yarn workspace @nutrition/api dev\"",
    "docker:up": "node scripts/compose-with-encrypted-env.mjs up -d",
    "docker:down": "node scripts/compose-with-encrypted-env.mjs down",
    "start:decrypted": "yarn workspace @nutrition/api start:prod",
    "env:encrypt": "node scripts/encrypt-env.mjs .env .env.encrypted",
    "db:migrate:dev": "node scripts/run-with-encrypted-env.mjs \"yarn workspace @nutrition/api prisma:migrate:dev\"",
    "db:migrate": "node scripts/run-with-encrypted-env.mjs \"yarn workspace @nutrition/api prisma:migrate:deploy\"",
    "docker:api:dev": "node scripts/run-with-encrypted-env.mjs \"yarn workspace @nutrition/api prisma:generate && yarn workspace @nutrition/api prisma:db:push && yarn workspace @nutrition/api dev\"",
    "test:model:carbonara": "node scripts/test-carbonara-model.mjs",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
