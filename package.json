{
  "name": "nutrition-assistant",
  "version": "0.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:api": "yarn workspace @nutrition/api dev",
    "start:decrypted": "yarn workspace @nutrition/api start:prod",
    "env:encrypt": "node scripts/encrypt-env.mjs .env.local .env.encrypted",
    "db:migrate:dev": "yarn workspace @nutrition/api prisma:migrate:dev",
    "db:migrate": "yarn workspace @nutrition/api prisma:migrate:deploy",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@1.22.22"
}
