# Application
NODE_ENV=development
PORT=3000

# Database
POSTGRES_USER=nutrition
POSTGRES_PASSWORD=nutrition_dev
POSTGRES_DB=nutrition_assistant
DATABASE_URL=postgresql://nutrition:nutrition_dev@localhost:5432/nutrition_assistant

# JWT
JWT_SECRET=your-secret-min-16-characters
JWT_EXPIRES_IN=7d
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
APP_BASE_URL=http://localhost:8081
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@nutrition-assistant.local
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Mobile
API_URL=http://localhost:3000
