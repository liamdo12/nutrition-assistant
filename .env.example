# =========================
# Core app
# =========================
# This file is a bootstrap template to create `.env.encrypted`.
# Runtime should read values from `.env.encrypted` + MASTER_KEY in process.env.
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# MASTER_KEY is only for decrypting `.env.encrypted`.
# Do not commit a real value to git.
MASTER_KEY=<SET_YOUR_MASTER_KEY>

# Optional override for encrypted file path.
# When empty, loader defaults to ./.env.encrypted
ENV_ENCRYPTED_PATH=.env.encrypted

# =========================
# Database
# =========================
POSTGRES_USER=nutrition
POSTGRES_PASSWORD=nutrition_dev
POSTGRES_DB=nutrition_assistant
# Docker Compose API container should use host `postgres`
DATABASE_URL=postgresql://nutrition:nutrition_dev@postgres:5432/nutrition_assistant

# =========================
# Auth
# =========================
JWT_SECRET=d533a8000e6552ec256da826c39454a4220081988cab0f10e5e62d6ca67763d2
JWT_EXPIRES_IN=7d
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m

# =========================
# App URLs / CORS
# =========================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
APP_BASE_URL=http://localhost:8081

# =========================
# Email
# =========================
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@nutrition-assistant.local
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
