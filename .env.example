# =========================
# Core app
# =========================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# MASTER_KEY is only for decrypting `.env.encrypted`.
# Do not commit a real value to git.
MASTER_KEY=<SET_STRONG_MASTER_KEY_HERE>

# Optional override for encrypted file path.
# When empty, loader defaults to ./.env.encrypted
ENV_ENCRYPTED_PATH=.env.encrypted

# =========================
# Database
# =========================
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=<POSTGRES_DB>
# Docker Compose API container should use host `postgres`
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@postgres:5432/<POSTGRES_DB>

# =========================
# Auth
# =========================
JWT_SECRET=<JWT_SECRET_MIN_16_CHARS>
JWT_EXPIRES_IN=7d
RESET_PASSWORD_TOKEN_EXPIRES_IN=15m

# =========================
# App URLs / CORS
# =========================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
APP_BASE_URL=http://localhost:8081

# =========================
# Email
# =========================
EMAIL_PROVIDER=log
EMAIL_FROM=no-reply@example.com
RESEND_API_KEY=<RESEND_API_KEY_OPTIONAL>
SMTP_HOST=<SMTP_HOST_OPTIONAL>
SMTP_PORT=587
SMTP_USER=<SMTP_USER_OPTIONAL>
SMTP_PASS=<SMTP_PASS_OPTIONAL>
SMTP_SECURE=false
